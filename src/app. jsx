import React, { useState, useEffect } from 'react';
import { ShoppingCart, Search, MapPin, Package, LogOut, Home, Plus, Minus, X, Truck } from 'lucide-react';

const GroceryApp = () => {
  const [screen, setScreen] = useState('home');
  const [user, setUser] = useState(null);
  const [cart, setCart] = useState([]);
  const [searchTerm, setSearchTerm] = useState('');
  const [orders, setOrders] = useState([]);
  const [selectedProduct, setSelectedProduct] = useState(null);

  const products = [
    { id: 1, name: 'Tomato', category: 'vegetables', price: 20, unit: 'kg', icon: '🍅', rating: 4.5 },
    { id: 2, name: 'Onion', category: 'vegetables', price: 25, unit: 'kg', icon: '🧅', rating: 4.3 },
    { id: 3, name: 'Potato', category: 'vegetables', price: 18, unit: 'kg', icon: '🥔', rating: 4.4 },
    { id: 4, name: 'Carrot', category: 'vegetables', price: 35, unit: 'kg', icon: '🥕', rating: 4.6 },
    { id: 5, name: 'Milk', category: 'dairy', price: 45, unit: 'liter', icon: '🥛', rating: 4.8 },
    { id: 6, name: 'Bread', category: 'bakery', price: 40, unit: 'pack', icon: '🍞', rating: 4.5 },
    { id: 7, name: 'Rice', category: 'groceries', price: 55, unit: 'kg', icon: '🌾', rating: 4.7 },
    { id: 8, name: 'Egg (6pcs)', category: 'dairy', price: 30, unit: 'pack', icon: '🥚', rating: 4.6 },
    { id: 9, name: 'Banana', category: 'fruits', price: 50, unit: 'kg', icon: '🍌', rating: 4.5 },
    { id: 10, name: 'Apple', category: 'fruits', price: 80, unit: 'kg', icon: '🍎', rating: 4.7 },
    { id: 11, name: 'Butter', category: 'dairy', price: 120, unit: '200g', icon: '🧈', rating: 4.6 },
    { id: 12, name: 'Cooking Oil', category: 'groceries', price: 150, unit: 'liter', icon: '🛢️', rating: 4.4 },
  ];

  useEffect(() => {
    const stored = localStorage.getItem('groceryCart');
    if (stored) setCart(JSON.parse(stored));
    const storedOrders = localStorage.getItem('groceryOrders');
    if (storedOrders) setOrders(JSON.parse(storedOrders));
  }, []);

  useEffect(() => {
    localStorage.setItem('groceryCart', JSON.stringify(cart));
  }, [cart]);

  const handleLogin = (name) => {
    setUser({ name, address: 'Bhubaneswar, Odisha' });
    setScreen('home');
  };

  const handleLogout = () => {
    setUser(null);
    setCart([]);
    setScreen('login');
  };

  const filteredProducts = products.filter(p =>
    p.name.toLowerCase().includes(searchTerm.toLowerCase())
  );

  const addToCart = (product) => {
    const existing = cart.find(item => item.id === product.id);
    if (existing) {
      setCart(cart.map(item =>
        item.id === product.id ? { ...item, qty: item.qty + 1 } : item
      ));
    } else {
      setCart([...cart, { ...product, qty: 1 }]);
    }
  };

  const updateCartQty = (productId, qty) => {
    if (qty <= 0) {
      setCart(cart.filter(item => item.id !== productId));
    } else {
      setCart(cart.map(item =>
        item.id === productId ? { ...item, qty } : item
      ));
    }
  };

  const removeFromCart = (productId) => {
    setCart(cart.filter(item => item.id !== productId));
  };

  const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
  const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);

  const handleCheckout = () => {
    if (cart.length === 0) return;
    
    const order = {
      id: Math.floor(Math.random() * 100000),
      date: new Date().toLocaleDateString(),
      time: new Date().toLocaleTimeString(),
      items: cart,
      total: totalPrice,
      status: 'Processing',
      eta: '15-20 mins'
    };
    
    setOrders([order, ...orders]);
    localStorage.setItem('groceryOrders', JSON.stringify([order, ...orders]));
    setCart([]);
    setScreen('success');
    setTimeout(() => setScreen('home'), 2000);
  };

  if (!user) {
    return (
      <div style={{ minHeight: '100vh', background: 'var(--surface-0)', padding: '20px', display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center', textAlign: 'center' }}>
        <div style={{ fontSize: '48px', marginBottom: '20px' }}>🛒</div>
        <h1 style={{ fontSize: '24px', fontWeight: 600, marginBottom: '10px', color: 'var(--text-primary)' }}>FreshCart</h1>
        <p style={{ color: 'var(--text-secondary)', marginBottom: '30px' }}>Organic vegetables & groceries at lowest prices</p>
        
        <div style={{ display: 'flex', flexDirection: 'column', gap: '12px', width: '100%', maxWidth: '300px' }}>
          <button onClick={() => handleLogin('Akash')} style={{ padding: '14px', background: '#378ADD', color: 'white', border: 'none', borderRadius: '8px', fontSize: '16px', fontWeight: 500, cursor: 'pointer' }}>
            Continue as Akash
          </button>
          <button onClick={() => handleLogin('Guest')} style={{ padding: '14px', background: 'var(--surface-1)', color: 'var(--text-primary)', border: '0.5px solid var(--border)', borderRadius: '8px', fontSize: '16px', cursor: 'pointer' }}>
            Continue as Guest
          </button>
        </div>
      </div>
    );
  }

  if (screen === 'success') {
    return (
      <div style={{ minHeight: '100vh', background: 'var(--surface-0)', padding: '40px 20px', display: 'flex', flexDirection: 'column', justifyContent: 'center', alignItems: 'center', textAlign: 'center' }}>
        <div style={{ fontSize: '64px', marginBottom: '20px' }}>✓</div>
        <h2 style={{ fontSize: '22px', fontWeight: 600, color: 'var(--text-primary)', marginBottom: '10px' }}>Order Confirmed!</h2>
        <p style={{ color: 'var(--text-secondary)' }}>Your groceries are being prepared</p>
      </div>
    );
  }

  if (screen === 'home') {
    return (
      <div style={{ minHeight: '100vh', background: 'var(--surface-0)', paddingBottom: '80px' }}>
        <div style={{ background: '#378ADD', color: 'white', padding: '16px', display: 'flex', justifyContent: 'space-between', alignItems: 'center', position: 'sticky', top: 0, zIndex: 10 }}>
          <div style={{ fontSize: '18px', fontWeight: 600 }}>FreshCart</div>
          <button onClick={handleLogout} style={{ background: 'rgba(255,255,255,0.2)', border: 'none', color: 'white', padding: '8px 12px', borderRadius: '6px', cursor: 'pointer', fontSize: '14px' }}>
            Logout
          </button>
        </div>

        <div style={{ background: 'var(--surface-1)', padding: '16px', borderBottom: '0.5px solid var(--border)' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: '8px', fontSize: '14px', color: 'var(--text-secondary)', marginBottom: '12px' }}>
            <MapPin size={16} /> {user.address}
          </div>
          <div style={{ display: 'flex', gap: '8px', alignItems: 'center' }}>
            <div style={{ flex: 1, display: 'flex', alignItems: 'center', gap: '8px', background: 'var(--surface-2)', padding: '10px 12px', borderRadius: '8px', border: '0.5px solid var(--border)' }}>
              <Search size={18} style={{ color: 'var(--text-secondary)' }} />
              <input
                type="text"
                placeholder="Search vegetables, dairy..."
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                style={{ flex: 1, border: 'none', background: 'transparent', fontSize: '14px', outline: 'none', color: 'var(--text-primary)' }}
              />
            </div>
            <button onClick={() => setScreen('cart')} style={{ position: 'relative', background: 'var(--surface-2)', border: '0.5px solid var(--border)', padding: '10px 12px', borderRadius: '8px', cursor: 'pointer' }}>
              <ShoppingCart size={20} />
              {totalItems > 0 && <span style={{ position: 'absolute', top: '-8px', right: '-8px', background: '#E24B4A', color: 'white', width: '20px', height: '20px', borderRadius: '50%', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '12px', fontWeight: 600 }}>{totalItems}</span>}
            </button>
          </div>
        </div>

        <div style={{ padding: '16px', display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: '12px' }}>
          {filteredProducts.map(product => (
            <div
              key={product.id}
              style={{ background: 'var(--surface-1)', borderRadius: '12px', border: '0.5px solid var(--border)', overflow: 'hidden', cursor: 'pointer' }}
              onClick={() => setSelectedProduct(product)}
            >
              <div style={{ fontSize: '40px', background: 'var(--surface-2)', padding: '16px', textAlign: 'center' }}>
                {product.icon}
              </div>
              <div style={{ padding: '12px' }}>
                <div style={{ fontSize: '14px', fontWeight: 500, color: 'var(--text-primary)', marginBottom: '4px' }}>
                  {product.name}
                </div>
                <div style={{ fontSize: '12px', color: 'var(--text-secondary)', marginBottom: '8px' }}>
                  ₹{product.price}/{product.unit}
                </div>
                <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                  <span style={{ fontSize: '12px', color: 'var(--text-secondary)' }}>★ {product.rating}</span>
                  <button
                    onClick={(e) => { e.stopPropagation(); addToCart(product); }}
                    style={{ background: '#378ADD', color: 'white', border: 'none', padding: '6px 12px', borderRadius: '6px', fontSize: '12px', cursor: 'pointer', fontWeight: 500 }}
                  >
                    Add
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>

        {selectedProduct && (
          <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.5)', display: 'flex', alignItems: 'flex-end', zIndex: 100 }}>
            <div style={{ width: '100%', background: 'var(--surface-1)', borderRadius: '16px 16px 0 0', padding: '20px', maxHeight: '70vh', overflowY: 'auto' }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px' }}>
                <h2 style={{ fontSize: '18px', fontWeight: 600 }}>Product Details</h2>
                <button onClick={() => setSelectedProduct(null)} style={{ background: 'none', border: 'none', fontSize: '24px', cursor: 'pointer' }}>×</button>
              </div>
              <div style={{ fontSize: '64px', textAlign: 'center', marginBottom: '16px' }}>{selectedProduct.icon}</div>
              <h3 style={{ fontSize: '20px', fontWeight: 600, marginBottom: '8px' }}>{selectedProduct.name}</h3>
              <p style={{ color: 'var(--text-secondary)', marginBottom: '16px' }}>Fresh, organic {selectedProduct.category}</p>
              <div style={{ fontSize: '24px', fontWeight: 700, color: '#378ADD', marginBottom: '16px' }}>
                ₹{selectedProduct.price}<span style={{ fontSize: '14px', color: 'var(--text-secondary)' }}>/{selectedProduct.unit}</span>
              </div>
              <button
                onClick={() => { addToCart(selectedProduct); setSelectedProduct(null); }}
                style={{ width: '100%', background: '#378ADD', color: 'white', padding: '12px', borderRadius: '8px', border: 'none', fontSize: '16px', fontWeight: 600, cursor: 'pointer' }}
              >
                Add to Cart
              </button>
            </div>
          </div>
        )}

        <div style={{ position: 'fixed', bottom: 0, left: 0, right: 0, background: 'var(--surface-1)', borderTop: '0.5px solid var(--border)', display: 'flex', justifyContent: 'space-around', padding: '12px 0' }}>
          <button onClick={() => setScreen('home')} style={{ flex: 1, background: 'none', border: 'none', padding: '8px', cursor: 'pointer', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', color: '#378ADD' }}>
            <Home size={20} /> <span style={{ fontSize: '12px' }}>Home</span>
          </button>
          <button onClick={() => setScreen('orders')} style={{ flex: 1, background: 'none', border: 'none', padding: '8px', cursor: 'pointer', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', color: 'var(--text-secondary)' }}>
            <Package size={20} /> <span style={{ fontSize: '12px' }}>Orders</span>
          </button>
          <button onClick={() => setScreen('cart')} style={{ flex: 1, background: 'none', border: 'none', padding: '8px', cursor: 'pointer', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', color: totalItems > 0 ? '#378ADD' : 'var(--text-secondary)' }}>
            <ShoppingCart size={20} /> <span style={{ fontSize: '12px' }}>Cart{totalItems > 0 ? ` (${totalItems})` : ''}</span>
          </button>
        </div>
      </div>
    );
  }

  if (screen === 'cart') {
    return (
      <div style={{ minHeight: '100vh', background: 'var(--surface-0)', paddingBottom: '180px' }}>
        <div style={{ background: '#378ADD', color: 'white', padding: '16px', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <h2 style={{ fontSize: '18px', fontWeight: 600 }}>Shopping Cart</h2>
          <button onClick={() => setScreen('home')} style={{ background: 'rgba(255,255,255,0.2)', border: 'none', color: 'white', padding: '8px 12px', borderRadius: '6px', cursor: 'pointer' }}>
            Back
          </button>
        </div>

        {cart.length === 0 ? (
          <div style={{ padding: '40px 20px', textAlign: 'center' }}>
            <div style={{ fontSize: '48px', marginBottom: '16px' }}>🛒</div>
            <p style={{ color: 'var(--text-secondary)' }}>Your cart is empty</p>
          </div>
        ) : (
          <>
            <div style={{ padding: '16px', display: 'flex', flexDirection: 'column', gap: '12px' }}>
              {cart.map(item => (
                <div key={item.id} style={{ background: 'var(--surface-1)', borderRadius: '12px', border: '0.5px solid var(--border)', padding: '12px', display: 'flex', alignItems: 'center', gap: '12px' }}>
                  <div style={{ fontSize: '32px' }}>{item.icon}</div>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontSize: '14px', fontWeight: 500, marginBottom: '4px' }}>{item.name}</div>
                    <div style={{ fontSize: '12px', color: 'var(--text-secondary)' }}>₹{item.price}/{item.unit}</div>
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: '8px', background: 'var(--surface-0)', borderRadius: '6px', padding: '4px' }}>
                    <button onClick={() => updateCartQty(item.id, item.qty - 1)} style={{ background: 'none', border: 'none', padding: '4px 8px', cursor: 'pointer', fontSize: '16px' }}>
                      <Minus size={16} />
                    </button>
                    <span style={{ minWidth: '24px', textAlign: 'center', fontSize: '14px', fontWeight: 500 }}>{item.qty}</span>
                    <button onClick={() => updateCartQty(item.id, item.qty + 1)} style={{ background: 'none', border: 'none', padding: '4px 8px', cursor: 'pointer', fontSize: '16px' }}>
                      <Plus size={16} />
                    </button>
                  </div>
                  <div style={{ minWidth: '60px', textAlign: 'right', fontWeight: 600 }}>₹{(item.price * item.qty).toFixed(0)}</div>
                  <button onClick={() => removeFromCart(item.id)} style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--text-secondary)' }}>
                    <X size={18} />
                  </button>
                </div>
              ))}
            </div>

            <div style={{ position: 'fixed', bottom: 0, left: 0, right: 0, background: 'var(--surface-1)', borderTop: '0.5px solid var(--border)', padding: '16px' }}>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '12px', fontSize: '14px' }}>
                <span>Subtotal:</span>
                <span>₹{totalPrice}</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '12px', fontSize: '14px', color: 'var(--text-secondary)' }}>
                <span>Delivery:</span>
                <span>Free</span>
              </div>
              <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '16px', fontSize: '16px', fontWeight: 600, paddingTop: '12px', borderTop: '0.5px solid var(--border)' }}>
                <span>Total:</span>
                <span>₹{totalPrice}</span>
              </div>
              <button
                onClick={handleCheckout}
                style={{ width: '100%', background: '#378ADD', color: 'white', padding: '14px', borderRadius: '8px', border: 'none', fontSize: '16px', fontWeight: 600, cursor: 'pointer' }}
              >
                Checkout
              </button>
            </div>
          </>
        )}
      </div>
    );
  }

  if (screen === 'orders') {
    return (
      <div style={{ minHeight: '100vh', background: 'var(--surface-0)', paddingBottom: '80px' }}>
        <div style={{ background: '#378ADD', color: 'white', padding: '16px', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <h2 style={{ fontSize: '18px', fontWeight: 600 }}>Your Orders</h2>
          <button onClick={() => setScreen('home')} style={{ background: 'rgba(255,255,255,0.2)', border: 'none', color: 'white', padding: '8px 12px', borderRadius: '6px', cursor: 'pointer' }}>
            Back
          </button>
        </div>

        {orders.length === 0 ? (
          <div style={{ padding: '40px 20px', textAlign: 'center' }}>
            <div style={{ fontSize: '48px', marginBottom: '16px' }}>📦</div>
            <p style={{ color: 'var(--text-secondary)' }}>No orders yet</p>
          </div>
        ) : (
          <div style={{ padding: '16px', display: 'flex', flexDirection: 'column', gap: '12px' }}>
            {orders.map(order => (
              <div key={order.id} style={{ background: 'var(--surface-1)', borderRadius: '12px', border: '0.5px solid var(--border)', padding: '16px' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start', marginBottom: '12px' }}>
                  <div>
                    <div style={{ fontSize: '14px', fontWeight: 600, marginBottom: '4px' }}>Order #{order.id}</div>
                    <div style={{ fontSize: '12px', color: 'var(--text-secondary)' }}>{order.date} at {order.time}</div>
                  </div>
                  <span style={{ background: '#EAF3DE', color: '#3B6D11', padding: '4px 12px', borderRadius: '6px', fontSize: '12px', fontWeight: 500 }}>
                    {order.status}
                  </span>
                </div>
                <div style={{ fontSize: '12px', color: 'var(--text-secondary)', marginBottom: '12px', paddingBottom: '12px', borderBottom: '0.5px solid var(--border)' }}>
                  {order.items.length} item{order.items.length > 1 ? 's' : ''} • ₹{order.total}
                </div>
                <div style={{ display: 'flex', alignItems: 'center', gap: '8px', fontSize: '12px', color: '#378ADD' }}>
                  <Truck size={14} /> Arriving in {order.eta}
                </div>
              </div>
            ))}
          </div>
        )}

        <div style={{ position: 'fixed', bottom: 0, left: 0, right: 0, background: 'var(--surface-1)', borderTop: '0.5px solid var(--border)', display: 'flex', justifyContent: 'space-around', padding: '12px 0' }}>
          <button onClick={() => setScreen('home')} style={{ flex: 1, background: 'none', border: 'none', padding: '8px', cursor: 'pointer', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', color: 'var(--text-secondary)' }}>
            <Home size={20} /> <span style={{ fontSize: '12px' }}>Home</span>
          </button>
          <button onClick={() => setScreen('orders')} style={{ flex: 1, background: 'none', border: 'none', padding: '8px', cursor: 'pointer', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', color: '#378ADD' }}>
            <Package size={20} /> <span style={{ fontSize: '12px' }}>Orders</span>
          </button>
          <button onClick={() => setScreen('cart')} style={{ flex: 1, background: 'none', border: 'none', padding: '8px', cursor: 'pointer', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', color: totalItems > 0 ? '#378ADD' : 'var(--text-secondary)' }}>
            <ShoppingCart size={20} /> <span style={{ fontSize: '12px' }}>Cart{totalItems > 0 ? ` (${totalItems})` : ''}</span>
          </button>
        </div>
      </div>
    );
  }
};

export default GroceryApp;
